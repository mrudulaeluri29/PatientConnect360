generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                    @id @default(cuid())
  email                 String                    @unique
  username              String                    @unique
  passwordHash          String
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  role                  Role                      @default(PATIENT)
  failedLoginAttempts   Int                       @default(0)
  lastFailedAt          DateTime?
  lastLogin             DateTime?
  passwordResetAttempts Int                       @default(0)
  passwordResetExpiry   DateTime?
  passwordResetToken    String?
  adminProfile          AdminProfile?
  auditLogs             AuditLog[]                @relation("AuditActor")
  caregiverInvitations  CaregiverInvitation[]     @relation("PatientInvitations")
  usedInvitations       CaregiverInvitation[]     @relation("CaregiverInvitationsUsed")
  caregiverLinks        CaregiverPatientLink[]    @relation("CaregiverLinks")
  patientCaregiverLinks CaregiverPatientLink[]    @relation("PatientCaregiverLinks")
  caregiverProfile      CaregiverProfile?
  availability          ClinicianAvailability[]   @relation("ClinicianAvailability")
  clinicianProfile      ClinicianProfile?
  conversations         ConversationParticipant[]
  conversationStars     ConversationStar[]
  patientFeedback       FamilyFeedback[]          @relation("PatientFeedback")
  submittedFeedback     FamilyFeedback[]          @relation("SubmittedFeedback")
  medications           Medication[]              @relation("PatientMedications")
  prescribed            Medication[]              @relation("PrescribedMedications")
  sentMessages          Message[]                 @relation("SentMessages")
  notifications         Notification[]
  outboundNotifications OutboundNotification[]
  assignedTo            PatientAssignment[]       @relation("AssignedClinician")
  assignments           PatientAssignment[]       @relation("AssignedPatients")
  patientProfile        PatientProfile?
  clinicianVisits       Visit[]                   @relation("ClinicianVisits")
  patientVisits         Visit[]                   @relation("PatientVisits")
  reminderPreference    VisitReminderPreference?
  vitals                VitalSign[]               @relation("PatientVitals")
  recordedVitals        VitalSign[]               @relation("RecordedVitals")
  createdExercises      Exercise[]             @relation("CreatedExercises")
  hepAssignments        ExerciseAssignment[]   @relation("PatientAssignments_HEP")
  hepAssigned           ExerciseAssignment[]   @relation("ClinicianAssignments_HEP")
  hepCompletions        ExerciseCompletion[]   @relation("HEPCompletions")
  clinicianPrepTasks    VisitPrepTask[]        @relation("ClinicianPrepTasks")
  prepTasksDone         VisitPrepTask[]        @relation("PrepTaskCompletions")
  patientCarePlans      CarePlan[]             @relation("PatientCarePlans")
  clinicianCreatedCarePlans CarePlan[]         @relation("ClinicianCarePlans")
  adminCreatedCarePlans CarePlan[]             @relation("AdminCarePlans")
  carePlanProgressAsPatient CarePlanItemProgress[] @relation("CarePlanProgressPatient")
  carePlanProgressUpdates CarePlanItemProgress[]   @relation("CarePlanProgressUpdater")
  carePlanCheckInsSubmitted CarePlanCheckIn[]      @relation("CarePlanCheckInAuthor")
  patientDocuments      PatientDocument[]      @relation("PatientDocumentsPatient")
  uploadedPatientDocuments PatientDocument[]   @relation("PatientDocumentUploader")
  visitSummariesAuthored Visit[]               @relation("VisitSummaryAuthor")
  activityRollups       UserActivityDaily[]    @relation("UserActivityRollups")
}

model AgencySettings {
  id           String   @id @default("default")
  portalName   String   @default("MediHealth")
  logoUrl      String?
  primaryColor String   @default("#6E5B9A")
  supportEmail String?
  supportPhone String?
  supportName  String?
  supportHours String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id          String          @id @default(cuid())
  actorId     String?
  actorRole   Role?
  actionType  AuditActionType
  targetType  String?
  targetId    String?
  description String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  actor       User?           @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([actionType])
  @@index([createdAt])
  @@index([targetType, targetId])
}

model PatientProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  legalName             String
  dateOfBirth           DateTime
  phoneNumber           String
  homeAddress           String
  apartmentSuite        String?
  insuranceProvider     String
  insurancePolicyNumber String
  preferredPharmacyName String
  pharmacyAddress       String
  pharmacyPhoneNumber   String
  uploadedFileName      String?
  uploadedFileUrl       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  username              String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClinicianProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  specialization      String?
  licenseNumber       String?
  hospitalAffiliation String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  username            String?
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CaregiverProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  relationship   String?
  certifications String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  legalFirstName String?
  legalLastName  String?
  phoneNumber    String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdminProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  displayName           String?
  phoneNumber           String?
  emergencyContactEmail String?
  emergencyContactPhone String?
  superAdmin            Boolean   @default(false)
  notes                 String?
  lastSecurityAudit     DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PatientAssignment {
  id          String   @id @default(cuid())
  patientId   String
  clinicianId String
  assignedAt  DateTime @default(now())
  assignedBy  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clinician   User     @relation("AssignedClinician", fields: [clinicianId], references: [id], onDelete: Cascade)
  patient     User     @relation("AssignedPatients", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, clinicianId])
  @@index([patientId])
  @@index([clinicianId])
}

model PendingVerification {
  id         String    @id @default(cuid())
  email      String    @unique
  pending    Json
  attempts   Int       @default(0)
  lastSentAt DateTime?
  createdAt  DateTime  @default(now())
}

model Conversation {
  id           String                    @id @default(cuid())
  subject      String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  stars        ConversationStar[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  unreadCount    Int          @default(0)
  lastReadAt     DateTime?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Visit {
  id                        String           @id @default(cuid())
  patientId                 String
  clinicianId               String
  scheduledAt               DateTime
  durationMinutes           Int              @default(60)
  status                    VisitStatus      @default(SCHEDULED)
  visitType                 VisitType        @default(HOME_HEALTH)
  purpose                   String?
  address                   String?
  notes                     String?
  clinicianNotes            String?
  checkedInAt               DateTime?
  completedAt               DateTime?
  cancelledAt               DateTime?
  cancelReason              String?
  createdBy                 String?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  cancellationRequestedAt   DateTime?
  cancellationRequestedById String?
  originalVisitId           String?
  requestType               VisitRequestType @default(INITIAL)
  requestedById             String?
  rescheduleReason          String?
  reviewNote                String?
  reviewedAt                DateTime?
  reviewedByAdminId         String?
  clinician                 User             @relation("ClinicianVisits", fields: [clinicianId], references: [id], onDelete: Cascade)
  originalVisit             Visit?           @relation("VisitRescheduleChain", fields: [originalVisitId], references: [id])
  rescheduleChildren        Visit[]          @relation("VisitRescheduleChain")
  hepAssignments            ExerciseAssignment[]
  prepTasks                 VisitPrepTask[]
  patient                   User             @relation("PatientVisits", fields: [patientId], references: [id], onDelete: Cascade)
  summaryDiagnosis       String?
  summaryCareProvided    String?
  summaryPatientResponse String?
  summaryFollowUp        String?
  medicationChangesSummary String?
  summaryUpdatedAt       DateTime?
  summaryUpdatedById     String?
  summaryUpdatedBy       User?            @relation("VisitSummaryAuthor", fields: [summaryUpdatedById], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([clinicianId])
  @@index([scheduledAt])
  @@index([status])
  @@index([originalVisitId])
  @@index([requestType])
}

model CarePlan {
  id                  String         @id @default(cuid())
  patientId           String
  createdByClinicianId String?
  createdByAdminId    String?
  status              CarePlanStatus @default(ACTIVE)
  reviewBy            DateTime?
  version             Int            @default(1)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  patient             User           @relation("PatientCarePlans", fields: [patientId], references: [id], onDelete: Cascade)
  createdByClinician  User?          @relation("ClinicianCarePlans", fields: [createdByClinicianId], references: [id], onDelete: SetNull)
  createdByAdmin      User?          @relation("AdminCarePlans", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  items               CarePlanItem[]
  checkIns            CarePlanCheckIn[]

  @@index([patientId])
  @@index([status])
}

model CarePlanItem {
  id         String           @id @default(cuid())
  carePlanId String
  type       CarePlanItemType
  title      String
  details    String?
  sortOrder  Int              @default(0)
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  carePlan   CarePlan         @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  progress   CarePlanItemProgress[]

  @@index([carePlanId])
}

model CarePlanItemProgress {
  id              String                     @id @default(cuid())
  carePlanItemId  String
  patientId       String
  updatedByUserId String
  status          CarePlanItemProgressStatus @default(NOT_STARTED)
  note            String?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  carePlanItem    CarePlanItem               @relation(fields: [carePlanItemId], references: [id], onDelete: Cascade)
  patient         User                       @relation("CarePlanProgressPatient", fields: [patientId], references: [id], onDelete: Cascade)
  updatedBy       User                       @relation("CarePlanProgressUpdater", fields: [updatedByUserId], references: [id], onDelete: Cascade)

  @@unique([carePlanItemId, patientId])
  @@index([patientId])
}

model CarePlanCheckIn {
  id              String                @id @default(cuid())
  carePlanId      String
  updatedByUserId String
  status          CarePlanCheckInStatus @default(OK)
  note            String?
  createdAt       DateTime              @default(now())
  carePlan        CarePlan              @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  updatedBy       User                  @relation("CarePlanCheckInAuthor", fields: [updatedByUserId], references: [id], onDelete: Cascade)

  @@index([carePlanId])
}

model PatientDocument {
  id               String   @id @default(cuid())
  patientId        String
  uploadedByUserId String
  docType          String
  filename         String
  contentType      String
  blobUrl          String
  blobPath         String
  blobContainer    String   @default("patient-documents")
  isHidden         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  patient          User     @relation("PatientDocumentsPatient", fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation("PatientDocumentUploader", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([isHidden])
}

model Medication {
  id            String              @id @default(cuid())
  patientId     String
  prescribedBy  String?
  name          String
  dosage        String
  frequency     String?
  startDate     DateTime?
  endDate       DateTime?
  status        MedicationStatus    @default(ACTIVE)
  riskLevel     MedicationRiskLevel @default(NORMAL)
  notes         String?
  refillDueDate DateTime?
  lastChangedAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  rxcui         String?
  patient       User                @relation("PatientMedications", fields: [patientId], references: [id], onDelete: Cascade)
  prescriber    User?               @relation("PrescribedMedications", fields: [prescribedBy], references: [id])

  @@index([patientId])
  @@index([status])
}

model VitalSign {
  id         String     @id @default(cuid())
  patientId  String
  recordedBy String?
  visitId    String?
  type       VitalType
  value      String
  unit       String?
  trend      VitalTrend @default(STABLE)
  notes      String?
  recordedAt DateTime   @default(now())
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  patient    User       @relation("PatientVitals", fields: [patientId], references: [id], onDelete: Cascade)
  recorder   User?      @relation("RecordedVitals", fields: [recordedBy], references: [id])

  @@index([patientId])
  @@index([type])
  @@index([recordedAt])
}

model ClinicianAvailability {
  id          String             @id @default(cuid())
  clinicianId String
  date        DateTime
  startTime   String
  endTime     String
  status      AvailabilityStatus @default(PENDING)
  reviewedBy  String?
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  clinician   User               @relation("ClinicianAvailability", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@unique([clinicianId, date])
  @@index([clinicianId])
  @@index([date])
  @@index([status])
}

model CaregiverInvitation {
  id           String           @id @default(cuid())
  patientId    String
  code         String           @unique
  firstName    String
  lastName     String
  email        String
  phoneNumber  String
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  patient      User             @relation("PatientInvitations", fields: [patientId], references: [id], onDelete: Cascade)
  usedBy       User?            @relation("CaregiverInvitationsUsed", fields: [usedByUserId], references: [id])

  @@index([patientId])
  @@index([code])
  @@index([expiresAt])
}

model CaregiverPatientLink {
  id           String   @id @default(cuid())
  caregiverId  String
  patientId    String
  invitationId String?
  relationship String?
  isPrimary    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  caregiver    User     @relation("CaregiverLinks", fields: [caregiverId], references: [id], onDelete: Cascade)
  patient      User     @relation("PatientCaregiverLinks", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, patientId])
  @@index([caregiverId])
  @@index([patientId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  meta      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model VisitReminderPreference {
  id       String          @id @default(cuid())
  userId   String          @unique
  channel  ReminderChannel @default(IN_APP_ONLY)
  timezone String?
  enabled  Boolean         @default(true)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OutboundNotification {
  id          String         @id @default(cuid())
  userId      String
  channel     String
  toAddress   String
  templateKey String
  payload     Json?
  status      OutboundStatus @default(PENDING)
  sendAt      DateTime
  sentAt      DateTime?
  error       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([sendAt])
  @@index([userId])
}

model ConversationStar {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  starredAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model FamilyFeedback {
  id                  String                  @id @default(cuid())
  patientId           String
  submittedByUserId   String
  eventType           FamilyFeedbackEventType
  relatedId           String?
  ratingHelpfulness   Int?
  ratingCommunication Int?
  comment             String?
  createdAt           DateTime                @default(now())
  patient             User                    @relation("PatientFeedback", fields: [patientId], references: [id], onDelete: Cascade)
  submittedBy         User                    @relation("SubmittedFeedback", fields: [submittedByUserId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([eventType])
  @@index([createdAt])
  @@index([submittedByUserId])
}

enum Role {
  ADMIN
  PATIENT
  CAREGIVER
  CLINICIAN
}

enum AuditActionType {
  LOGIN
  APPOINTMENT_APPROVED
  APPOINTMENT_REJECTED
  APPOINTMENT_CREATED
  APPOINTMENT_CANCELLED
  MED_CREATED
  MED_CHANGED
  MED_REMOVED
  CAREGIVER_LINK_UPDATED
  ASSIGNMENT_UPDATED
  AVAILABILITY_REVIEWED
  SETTINGS_UPDATED
  MESSAGE_SENT
  CONVERSATION_CREATED
  CAREGIVER_INVITATION_CREATED
  CAREGIVER_INVITATION_REVOKED
  CAREGIVER_LINK_CREATED
  AVAILABILITY_SUBMITTED
  VISIT_RESCHEDULE_REQUESTED
  VISIT_RESCHEDULE_APPROVED
  BRANDING_UPDATED
}

enum VisitStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
  RESCHEDULED
  REQUESTED
  RESCHEDULE_REQUESTED
  REJECTED
}

enum VisitRequestType {
  INITIAL
  RESCHEDULE
}

enum VisitType {
  HOME_HEALTH
  WOUND_CARE
  PHYSICAL_THERAPY
  OCCUPATIONAL_THERAPY
  SPEECH_THERAPY
  MEDICATION_REVIEW
  POST_DISCHARGE
  ROUTINE_CHECKUP
  OTHER
}

enum MedicationStatus {
  ACTIVE
  DISCONTINUED
  ON_HOLD
  COMPLETED
}

enum MedicationRiskLevel {
  NORMAL
  CHANGED
  HIGH_RISK
}

enum VitalType {
  BLOOD_PRESSURE
  HEART_RATE
  TEMPERATURE
  OXYGEN_SATURATION
  WEIGHT
  BLOOD_GLUCOSE
  PAIN_LEVEL
  RESPIRATORY_RATE
}

enum VitalTrend {
  IMPROVING
  STABLE
  DECLINING
  CRITICAL
}

enum AvailabilityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum NotificationType {
  VISIT_REQUEST_RECEIVED
  VISIT_APPROVED
  VISIT_DENIED
  VISIT_CANCELLED
  VISIT_REMINDER_24H
  VISIT_REMINDER_1H
  CAREPLAN_UPDATED
  MESSAGE_RECEIVED
}

enum FamilyFeedbackEventType {
  VISIT_COMPLETED
  MEDICATION_CHANGED
}

enum ReminderChannel {
  IN_APP_ONLY
  EMAIL
  SMS
  EMAIL_AND_SMS
}

enum OutboundStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum CarePlanStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum CarePlanItemType {
  PROBLEM
  GOAL
  INTERVENTION
}

enum CarePlanItemProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CarePlanCheckInStatus {
  OK
  FAIR
  NEEDS_ATTENTION
}
// ─── Feature 4: HEP + Visit Prep Tasks ──────────────────────────────────────

model Exercise {
  id                   String               @id @default(cuid())
  name                 String
  instructions         String
  createdByClinicianId String
  createdAt            DateTime             @default(now())
  createdByClinician   User                 @relation("CreatedExercises", fields: [createdByClinicianId], references: [id], onDelete: Cascade)
  assignments          ExerciseAssignment[]
}

model ExerciseAssignment {
  id                    String               @id @default(cuid())
  patientId             String
  assignedByClinicianId String
  exerciseId            String
  frequencyPerWeek      Int
  startDate             DateTime
  endDate               DateTime?
  status                HEPStatus            @default(ACTIVE)
  visitId               String?
  createdAt             DateTime             @default(now())
  patient               User                 @relation("PatientAssignments_HEP", fields: [patientId], references: [id], onDelete: Cascade)
  assignedByClinician   User                 @relation("ClinicianAssignments_HEP", fields: [assignedByClinicianId], references: [id], onDelete: Cascade)
  exercise              Exercise             @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  visit                 Visit?               @relation(fields: [visitId], references: [id])
  completions           ExerciseCompletion[]

  @@index([patientId])
  @@index([assignedByClinicianId])
  @@index([exerciseId])
}

model ExerciseCompletion {
  id                String             @id @default(cuid())
  assignmentId      String
  completedByUserId String
  completedAt       DateTime           @default(now())
  comment           String?
  assignment        ExerciseAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  completedByUser   User               @relation("HEPCompletions", fields: [completedByUserId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([completedByUserId])
}

model VisitPrepTask {
  id                   String    @id @default(cuid())
  visitId              String
  text                 String
  createdByClinicianId String
  isDone               Boolean   @default(false)
  doneByUserId         String?
  doneAt               DateTime?
  createdAt            DateTime  @default(now())
  visit                Visit     @relation(fields: [visitId], references: [id], onDelete: Cascade)
  createdByClinician   User      @relation("ClinicianPrepTasks", fields: [createdByClinicianId], references: [id], onDelete: Cascade)
  doneByUser           User?     @relation("PrepTaskCompletions", fields: [doneByUserId], references: [id])

  @@index([visitId])
  @@index([createdByClinicianId])
}

model UserActivityDaily {
  id         String   @id @default(cuid())
  userId     String
  day        DateTime
  lastSeenAt DateTime @default(now())
  eventCount Int      @default(1)
  user       User     @relation("UserActivityRollups", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([day])
  @@index([userId])
}

enum HEPStatus {
  ACTIVE
  PAUSED
  COMPLETED
}
