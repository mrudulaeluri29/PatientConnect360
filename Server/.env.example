# ---- Required ----
DATABASE_URL=postgresql://user:pass@host:5432/patientconnect360
PORT=4000
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
COOKIE_NAME=auth

# ---- Twilio (OTP) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ---- SendGrid (Email) ----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=PatientConnect360

# ---- Azure Blob Storage (Document Upload) ----
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=patient-documents
AZURE_BLOB_SAS_MINUTES=15

# ---- Admin Seed ----
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Admin
ADMIN_PHONE=+15551234567
ADMIN_OVERWRITE=false
ADMIN_SUPER=true

# ---- Feature Flags ----
ENABLE_OUTBOUND_REMINDERS=false
ENABLE_APPOINTMENT_EMAILS=false
AVAILABILITY_TIMEZONE=America/Phoenix

# ---- CORS (production) ----
CORS_ORIGINS=https://your-vercel-app.vercel.app

# ---- Optional: Seed Script Overrides ----
# FEATURE1_SEED_PATIENT_EMAIL=
# FEATURE1_SEED_CLINICIAN_EMAIL=
# FEATURE1_SEED_ADMIN_EMAIL=
# FEATURE4_SEED_PATIENT_EMAIL=
# FEATURE4_SEED_CLINICIAN_EMAIL=
# FEATURE4_SEED_CAREGIVER_EMAIL=

# ---- Feature 4 Integration Tests ----
# Required to run Feature 4 tests (Server/src/__tests__/feature4.*.test.ts).
# Set FEATURE_TEST_FAIL_FAST=1 in CI to fail instead of silently skipping.
# FEATURE_TEST_BASE_URL=http://localhost:4000
# FEATURE_TEST_PATIENT_LOGIN=
# FEATURE_TEST_PATIENT_PASSWORD=
# FEATURE_TEST_CLINICIAN_LOGIN=
# FEATURE_TEST_CLINICIAN_PASSWORD=
# FEATURE_TEST_ADMIN_LOGIN=
# FEATURE_TEST_ADMIN_PASSWORD=
# FEATURE_TEST_CAREGIVER_LOGIN=
# FEATURE_TEST_CAREGIVER_PASSWORD=
# FEATURE_TEST_FAIL_FAST=1

# ---- Schema note ----
# PatientPrivacySettings is intentionally managed by raw SQL in
# src/lib/privacySettings.ts and prisma/migrations/20260406160000_f6_privacy_consent.
# It does not currently have a Prisma model in schema.prisma.
